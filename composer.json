{
    "name": "vortexphp/admin",
    "description": "Admin UI package for Vortex (routes, views, assets via Package)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "vortexphp/framework": "^0.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vortex\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vortex\\Admin\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
