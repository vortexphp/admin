<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} — Admin</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="vortex-admin">
<header class="vortex-admin__bar">
    <a href="{{ route('admin.dashboard') }}" class="vortex-admin__brand">Admin</a>
    <span class="vortex-admin__crumb">{{ title }}</span>
</header>
<main class="vortex-admin__main">
    {% set flash = session_flash('admin_success') %}
    {% if flash %}
        <p class="vortex-admin__flash">{{ flash }}</p>
    {% endif %}

    <div class="vortex-admin__toolbar">
        <h1 class="vortex-admin__title">{{ title }}</h1>
        <a href="{{ route('admin.resource.create', { slug: slug }) }}" class="vortex-admin__btn">Create</a>
    </div>

    {% if tableFilters|length > 0 or perPageOptions|length > 1 %}
        <form method="get" action="{{ route('admin.resource.index', { slug: slug }) }}" class="vortex-admin__filters">
            {% for filter in tableFilters %}
                <div class="vortex-admin__filter">
                    <label class="vortex-admin__filter-label" for="adm_f_{{ attribute(filter, 'name') }}">{{ attribute(filter, 'label') }}</label>
                    {% set fp = filter.queryParam %}
                    {% if filter.inputKind == 'select' %}
                        <select id="adm_f_{{ attribute(filter, 'name') }}" name="{{ fp }}" class="vortex-admin__filter-input">
                            <option value="">— All —</option>
                            {% for optVal, optLabel in filter.options %}
                                <option value="{{ optVal }}" {% if attribute(filterValues, fp) == optVal %}selected{% endif %}>{{ optLabel }}</option>
                            {% endfor %}
                        </select>
                    {% else %}
                        <input id="adm_f_{{ attribute(filter, 'name') }}" type="text" name="{{ fp }}" value="{{ attribute(filterValues, fp)|default('') }}" class="vortex-admin__filter-input" autocomplete="off">
                    {% endif %}
                </div>
            {% endfor %}
            {% if perPageOptions|length > 1 %}
                <div class="vortex-admin__filter">
                    <label class="vortex-admin__filter-label" for="adm_per_page">Per page</label>
                    <select id="adm_per_page" name="per_page" class="vortex-admin__filter-input" aria-label="Rows per page" onchange="this.form.submit()">
                        {% for n in perPageOptions %}
                            <option value="{{ n }}" {% if n == tablePerPageCurrent %}selected{% endif %}>{{ n }}</option>
                        {% endfor %}
                    </select>
                </div>
            {% endif %}
            {% if tableFilters|length > 0 %}
                <div class="vortex-admin__filter-actions">
                    <button type="submit" class="vortex-admin__btn">Apply</button>
                    <a href="{{ route('admin.resource.index', { slug: slug }) }}" class="vortex-admin__btn vortex-admin__btn--ghost">Reset</a>
                </div>
            {% endif %}
        </form>
    {% endif %}

    <div class="vortex-admin__tablewrap">
        <table class="vortex-admin__table">
            <thead>
            <tr>
                {% for col in tableColumns %}
                    <th>{{ attribute(col, 'label') }}</th>
                {% endfor %}
                {% if tableActions|length > 0 %}
                    <th class="vortex-admin__actions" aria-label="Actions"></th>
                {% endif %}
            </tr>
            </thead>
            <tbody>
            {% for row in records %}
                {% set rowIndex = loop.index0 %}
                <tr>
                    {% for col in tableColumns %}
                        <td>{{ attribute(row, attribute(col, 'name')) }}</td>
                    {% endfor %}
                    {% if tableActions|length > 0 %}
                        <td class="vortex-admin__actions">
                            {% for act in tableRowActions[rowIndex] %}
                                {% if act.kind == 'link' %}
                                    <a href="{{ route(act.route, act.routeParams) }}">{{ act.label }}</a>
                                {% else %}
                                    <form method="post" action="{{ route(act.route, act.routeParams) }}" class="vortex-admin__inline-form">
                                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                        <button type="submit" class="vortex-admin__linkbtn">{{ act.label }}</button>
                                    </form>
                                {% endif %}
                            {% endfor %}
                        </td>
                    {% endif %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.hasPages %}
        <nav class="vortex-admin__pagination" aria-label="Pagination">
            {% if not pagination.onFirstPage %}
                <a href="{{ pagination.urlForPage(pagination.page - 1) }}" class="vortex-admin__btn vortex-admin__btn--ghost">Previous</a>
            {% endif %}
            <span class="vortex-admin__pagination-meta">Page {{ pagination.page }} of {{ pagination.last_page }} — {{ pagination.total }} total</span>
            {% if not pagination.onLastPage %}
                <a href="{{ pagination.urlForPage(pagination.page + 1) }}" class="vortex-admin__btn vortex-admin__btn--ghost">Next</a>
            {% endif %}
        </nav>
    {% endif %}
</main>
</body>
</html>
