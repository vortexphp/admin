{% extends 'admin/layout.twig' %}

{% block doc_title %}{{ title }} — Admin{% endblock %}

{% block heading %}{{ title }}{% endblock %}

{% block header_actions %}
    <a href="{{ route('admin.resource.create', { slug: slug }) }}" class="inline-flex items-center rounded-lg bg-zinc-100 px-3.5 py-2 text-sm font-medium text-zinc-950 shadow-sm transition-colors hover:bg-white">Create</a>
{% endblock %}

{% block body %}
<div class="mx-auto max-w-7xl space-y-5">
    {% set flash = session_flash('admin_success') %}
    {% if flash %}
        <p class="rounded-lg border border-zinc-700 bg-zinc-900/60 px-4 py-3 text-sm text-zinc-200 ring-1 ring-zinc-800/80">{{ flash }}</p>
    {% endif %}

    {% if tableFilters|length > 0 or perPageOptions|length > 1 %}
        <form method="get" action="{{ route('admin.resource.index', { slug: slug }) }}" class="flex flex-wrap items-end gap-4 rounded-xl border border-zinc-800/80 bg-zinc-900/25 p-4 ring-1 ring-zinc-800/60">
            {% for filter in tableFilters %}
                <div class="flex min-w-[10rem] flex-col gap-1">
                    <label class="text-xs font-medium text-zinc-500" for="adm_f_{{ attribute(filter, 'name') }}">{{ attribute(filter, 'label') }}</label>
                    {% set fp = filter.queryParam %}
                    {% if filter.inputKind == 'select' %}
                        <select id="adm_f_{{ attribute(filter, 'name') }}" name="{{ fp }}" class="rounded-lg border border-zinc-700 bg-zinc-950 px-2.5 py-2 text-sm text-zinc-100 shadow-sm focus:border-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-500/30">
                            <option value="">— All —</option>
                            {% for optVal, optLabel in filter.options %}
                                <option value="{{ optVal }}" {% if attribute(filterValues, fp) == optVal %}selected{% endif %}>{{ optLabel }}</option>
                            {% endfor %}
                        </select>
                    {% else %}
                        <input id="adm_f_{{ attribute(filter, 'name') }}" type="text" name="{{ fp }}" value="{{ attribute(filterValues, fp)|default('') }}" class="rounded-lg border border-zinc-700 bg-zinc-950 px-2.5 py-2 text-sm text-zinc-100 placeholder:text-zinc-600 shadow-sm focus:border-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-500/30" autocomplete="off">
                    {% endif %}
                </div>
            {% endfor %}
            {% if perPageOptions|length > 1 %}
                <div class="flex min-w-[10rem] flex-col gap-1">
                    <label class="text-xs font-medium text-zinc-500" for="adm_per_page">Per page</label>
                    <select id="adm_per_page" name="per_page" class="rounded-lg border border-zinc-700 bg-zinc-950 px-2.5 py-2 text-sm text-zinc-100 shadow-sm focus:border-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-500/30" aria-label="Rows per page" onchange="this.form.submit()">
                        {% for n in perPageOptions %}
                            <option value="{{ n }}" {% if n == tablePerPageCurrent %}selected{% endif %}>{{ n }}</option>
                        {% endfor %}
                    </select>
                </div>
            {% endif %}
            {% if tableFilters|length > 0 %}
                <div class="ml-auto flex items-center gap-2">
                    <button type="submit" class="inline-flex items-center rounded-lg bg-zinc-100 px-3.5 py-2 text-sm font-medium text-zinc-950 shadow-sm hover:bg-white">Apply</button>
                    <a href="{{ route('admin.resource.index', { slug: slug }) }}" class="inline-flex items-center rounded-lg border border-zinc-700 bg-transparent px-3.5 py-2 text-sm font-medium text-zinc-200 hover:bg-zinc-900/60">Reset</a>
                </div>
            {% endif %}
        </form>
    {% endif %}

    <div class="overflow-hidden rounded-xl border border-zinc-800/80 bg-zinc-900/10 shadow-sm ring-1 ring-zinc-800/60">
        <div class="overflow-x-auto">
            <table class="w-full border-collapse text-sm">
                <thead>
                <tr>
                    {% for col in tableColumns %}
                        <th class="border-b border-zinc-800 bg-zinc-900/70 px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-400">{{ col.label }}</th>
                    {% endfor %}
                    {% if tableActions|length > 0 %}
                        <th class="border-b border-zinc-800 bg-zinc-900/70 px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-zinc-400" aria-label="Actions"></th>
                    {% endif %}
                </tr>
                </thead>
                <tbody class="bg-zinc-950/30">
                {% for row in records %}
                    {% set rowIndex = loop.index0 %}
                    <tr class="border-b border-zinc-800/80 transition-colors last:border-0 hover:bg-zinc-900/35">
                        {% for col in tableColumns %}
                            {% set cell = attribute(row, col.name) %}
                            <td class="px-4 py-3 text-sm text-zinc-200 {% if col.kind in ['text', 'numeric', 'email', 'url', 'datetime', 'color', 'toggle'] %}whitespace-nowrap{% endif %}">
                                {% include 'admin/resource/cells/' ~ col.kind ~ '.twig' with { col: col, cell: cell } only %}
                            </td>
                        {% endfor %}
                        {% if tableActions|length > 0 %}
                            <td class="whitespace-nowrap px-4 py-3 text-right">
                                {% for act in tableRowActions[rowIndex] %}
                                    {% if act.kind == 'link' %}
                                        <a class="mr-3 text-sm text-zinc-300 underline decoration-zinc-600 underline-offset-2 transition-colors hover:text-white" href="{{ route(act.route, act.routeParams) }}">{{ act.label }}</a>
                                    {% else %}
                                        <form method="post" action="{{ route(act.route, act.routeParams) }}" class="inline">
                                            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                                            <button type="submit" class="cursor-pointer border-0 bg-transparent p-0 text-sm text-red-400/95 underline decoration-red-500/50 underline-offset-2 hover:text-red-300">{{ act.label }}</button>
                                        </form>
                                    {% endif %}
                                {% endfor %}
                            </td>
                        {% endif %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if pagination.hasPages %}
        <nav class="flex flex-wrap items-center justify-between gap-4 border-t border-zinc-800/80 pt-5" aria-label="Pagination">
            <span class="text-sm text-zinc-500">Page {{ pagination.page }} of {{ pagination.last_page }} · {{ pagination.total }} total</span>
            <div class="flex flex-wrap items-center gap-2">
                {% if not pagination.onFirstPage %}
                    <a href="{{ pagination.urlForPage(pagination.page - 1) }}" class="inline-flex items-center rounded-lg border border-zinc-700 bg-zinc-900/30 px-3.5 py-2 text-sm font-medium text-zinc-200 hover:bg-zinc-900/60">Previous</a>
                {% endif %}
                {% if not pagination.onLastPage %}
                    <a href="{{ pagination.urlForPage(pagination.page + 1) }}" class="inline-flex items-center rounded-lg border border-zinc-700 bg-zinc-900/30 px-3.5 py-2 text-sm font-medium text-zinc-200 hover:bg-zinc-900/60">Next</a>
                {% endif %}
            </div>
        </nav>
    {% endif %}
</div>
{% endblock %}
