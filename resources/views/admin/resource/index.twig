{% extends 'admin/layout.twig' %}

{% block doc_title %}{{ title }} — Admin{% endblock %}

{% block heading %}{{ title }}{% endblock %}

{% block header_actions %}
    {% import 'admin/partials/icon_svg.twig' as icons %}
    <a href="{{ route('admin.resource.create', { slug: slug }) }}" class="inline-flex items-center gap-2 rounded-lg border border-zinc-600/50 bg-zinc-100 px-3.5 py-2 text-sm font-medium text-zinc-950 shadow-sm ring-1 ring-zinc-800/40 transition-colors hover:bg-white">
        {{ icons.r('plus', 'h-4 w-4 shrink-0 text-zinc-700') }}
        <span>Create</span>
    </a>
{% endblock %}

{% block body %}
{% import 'admin/partials/icon_svg.twig' as icons %}
<div class="mx-auto max-w-7xl space-y-5">
    {% set flash = session_flash('admin_success') %}
    {% if flash %}
        <p class="flex items-center gap-2 rounded-lg border border-emerald-500/30 bg-emerald-500/5 px-4 py-3 text-sm text-emerald-100/90 ring-1 ring-emerald-500/20">
            {{ icons.r('check', 'h-4 w-4 shrink-0 text-emerald-400/90') }}
            <span>{{ flash }}</span>
        </p>
    {% endif %}

    {% include 'admin/partials/resource_index_table.twig' %}
</div>
{% endblock %}
