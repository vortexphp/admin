{% if formRichEditors.markdown %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.css" crossorigin="anonymous">
    <style>
        /* EasyMDE + CodeMirror: zinc admin shell (overrides easymde + CM defaults + Tailwind preflight). */
        .admin-markdown-field .EasyMDEContainer {
            width: 100%;
            border: 1px solid #3f3f46;
            border-radius: 0.5rem;
            overflow: hidden;
            background: #18181b;
            box-shadow: 0 0 0 1px rgba(24, 24, 27, 0.6);
        }
        .admin-markdown-field .EasyMDEContainer .editor-toolbar {
            position: relative;
            z-index: 2;
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.125rem;
            padding: 0.375rem 0.5rem;
            background: #27272a !important;
            border: none !important;
            border-bottom: 1px solid #3f3f46 !important;
            border-radius: 0 !important;
            opacity: 1 !important;
        }
        .admin-markdown-field .EasyMDEContainer .editor-toolbar::before,
        .admin-markdown-field .EasyMDEContainer .editor-toolbar::after { display: none !important; }
        .admin-markdown-field .editor-toolbar i.separator {
            border-left-color: #52525b !important;
            border-right-color: transparent !important;
        }
        .admin-markdown-field .editor-toolbar button {
            color: #e4e4e7 !important;
            background: transparent !important;
            border: 1px solid transparent !important;
            border-radius: 0.375rem !important;
            width: 1.85rem !important;
            height: 1.85rem !important;
            line-height: 1.85rem !important;
            text-align: center !important;
            padding: 0 !important;
        }
        .admin-markdown-field .editor-toolbar button:hover,
        .admin-markdown-field .editor-toolbar button.active {
            background: #3f3f46 !important;
            border-color: #52525b !important;
        }
        .admin-markdown-field .EasyMDEContainer .CodeMirror {
            color: #e4e4e7 !important;
            background: #18181b !important;
            border: none !important;
            border-radius: 0 !important;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
            font-size: 0.875rem !important;
            line-height: 1.55 !important;
        }
        .admin-markdown-field .EasyMDEContainer .CodeMirror-scroll { min-height: inherit; }
        .admin-markdown-field .EasyMDEContainer .CodeMirror-gutters {
            background: #27272a !important;
            border-right: 1px solid #3f3f46 !important;
        }
        .admin-markdown-field .EasyMDEContainer .CodeMirror-linenumber { color: #71717a !important; }
        .admin-markdown-field .EasyMDEContainer .CodeMirror-cursor { border-left: 2px solid #a1a1aa !important; }
        .admin-markdown-field .EasyMDEContainer .CodeMirror-selected { background: rgba(63, 63, 70, 0.55) !important; }
        .admin-markdown-field .cm-s-easymde .cm-comment { color: #a1a1aa !important; }
        .admin-markdown-field .cm-s-easymde .cm-string { color: #86efac !important; }
        .admin-markdown-field .cm-s-easymde .cm-url { color: #7dd3fc !important; }
        .admin-markdown-field .cm-s-easymde .cm-header { color: #fafafa !important; }
        .admin-markdown-field .cm-s-easymde .cm-quote { color: #d4d4d8 !important; font-style: italic; }
        .admin-markdown-field .cm-s-easymde .cm-link { color: #7dd3fc !important; }
        .admin-markdown-field .editor-preview,
        .admin-markdown-field .editor-preview-side {
            background: #18181b !important;
            color: #e4e4e7 !important;
            border-color: #3f3f46 !important;
            padding: 0.75rem 1rem;
        }
        .admin-markdown-field .editor-preview pre,
        .admin-markdown-field .editor-preview-side pre { background: #27272a !important; color: #e4e4e7 !important; }
        .admin-markdown-field .editor-statusbar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            padding: 0.35rem 0.65rem;
            background: #27272a !important;
            color: #a1a1aa !important;
            border-top: 1px solid #3f3f46 !important;
            font-size: 0.75rem !important;
        }
        .admin-markdown-field .editor-statusbar span { color: #a1a1aa !important; }
        .admin-markdown-field .editor-statusbar span.text { opacity: 0.95; }
        .admin-markdown-field .CodeMirror-fullscreen { z-index: 100 !important; background: #18181b !important; }
    </style>
{% endif %}
{% if formRichEditors.html %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" crossorigin="anonymous">
    <style>
        .ql-toolbar.ql-snow { background: #27272a; border-color: #3f3f46; }
        .ql-toolbar.ql-snow .ql-stroke { stroke: #d4d4d8; }
        .ql-toolbar.ql-snow .ql-fill { fill: #d4d4d8; }
        .ql-toolbar.ql-snow .ql-picker-label { color: #d4d4d8; }
        .ql-container.ql-snow { border-color: #3f3f46; background: #18181b; color: #e4e4e7; font-family: inherit; }
        .ql-editor { min-height: inherit; }
        .ql-editor.ql-blank::before { color: #71717a; }
    </style>
{% endif %}
{% if formRichEditors.tags %}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@yaireo/tagify@4.17.9/dist/tagify.css" crossorigin="anonymous">
    <style>
        .tagify { --tag-bg: #3f3f46; --tag-hover: #52525b; --tags-border-color: #3f3f46; background: #09090b; }
        .tagify__tag { color: #e4e4e7; }
        .tagify__input { color: #e4e4e7; }
    </style>
{% endif %}

{% if formRichEditors.markdown %}
    <script src="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.js" crossorigin="anonymous"></script>
{% endif %}
{% if formRichEditors.html %}
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js" crossorigin="anonymous"></script>
{% endif %}
{% if formRichEditors.tags %}
    <script src="https://cdn.jsdelivr.net/npm/@yaireo/tagify@4.17.9/dist/tagify.min.js" crossorigin="anonymous"></script>
{% endif %}

{% if formRichEditors.markdown or formRichEditors.html or formRichEditors.tags %}
<script>
(function () {
  function ready(fn) {
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn);
    else fn();
  }
  ready(function () {
    {% if formRichEditors.markdown %}
    if (typeof EasyMDE !== 'undefined') {
      document.querySelectorAll('[data-admin-markdown]').forEach(function (ta) {
        var h = parseInt(ta.getAttribute('data-min-height') || '280', 10);
        if (isNaN(h) || h < 120) h = 280;
        new EasyMDE({
          element: ta,
          spellChecker: false,
          /* Toolbar icons require Font Awesome; EasyMDE loads a compatible build from CDN. */
          autoDownloadFontAwesome: true,
          minHeight: h + 'px',
          status: ['lines', 'words', 'cursor'],
        });
      });
    }
    {% endif %}
    {% if formRichEditors.html %}
    if (typeof Quill !== 'undefined') {
      document.querySelectorAll('[data-admin-quill]').forEach(function (wrap) {
        var ta = wrap.querySelector('textarea');
        var edEl = wrap.querySelector('.admin-quill-editor');
        if (!ta || !edEl) return;
        var quill = new Quill(edEl, {
          theme: 'snow',
          modules: {
            toolbar: [
              [{ header: [1, 2, false] }],
              ['bold', 'italic', 'underline', 'link'],
              [{ list: 'ordered' }, { list: 'bullet' }],
              ['clean'],
            ],
          },
        });
        if (ta.value) quill.root.innerHTML = ta.value;
        var form = ta.form;
        if (form) {
          form.addEventListener('submit', function () {
            ta.value = quill.root.innerHTML;
          });
        }
      });
    }
    {% endif %}
    {% if formRichEditors.tags %}
    if (typeof Tagify !== 'undefined') {
      document.querySelectorAll('[data-admin-tagify]').forEach(function (inp) {
        var asJson = inp.getAttribute('data-as-json') === '1';
        var tagify = new Tagify(inp, { dropdown: { enabled: 0 } });
        var form = inp.form;
        if (form) {
          form.addEventListener('submit', function () {
            var vals = tagify.value.map(function (x) { return x.value; }).filter(Boolean);
            inp.value = asJson ? JSON.stringify(vals) : vals.join(',');
          });
        }
      });
    }
    {% endif %}
  });
})();
</script>
{% endif %}
