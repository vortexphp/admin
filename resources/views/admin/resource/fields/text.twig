<label class="text-xs font-medium text-zinc-500" for="field_{{ field.name }}">{{ field.label }}</label>
<input id="field_{{ field.name }}" type="text" name="{{ field.name }}" value="{{ values[field.name] ?? '' }}"
       class="rounded-lg border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm text-zinc-100 shadow-sm placeholder:text-zinc-600 focus:border-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-500/30"
       autocomplete="{{ field.autocomplete|default('off') }}">
