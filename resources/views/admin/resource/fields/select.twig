<label class="text-xs font-medium text-zinc-950 dark:text-zinc-500" for="field_{{ field.name }}">{{ field.label }}</label>
<select id="field_{{ field.name }}" name="{{ field.name }}"
        class="rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-950 px-3 py-2 text-sm text-zinc-900 dark:text-zinc-100 shadow-sm focus:border-zinc-500 dark:focus:border-zinc-500 focus:outline-none focus:ring-2 focus:ring-zinc-500/30 dark:focus:ring-zinc-500/30">
    {% if field.emptyOption|default(true) %}
        <option value="">{{ field.emptyLabel|default('— Select —') }}</option>
    {% endif %}
    {% for optVal, optLabel in field.options %}
        <option value="{{ optVal }}" {% if values[field.name] is defined and values[field.name] ~ '' == optVal ~ '' %}selected{% endif %}>{{ optLabel }}</option>
    {% endfor %}
</select>
