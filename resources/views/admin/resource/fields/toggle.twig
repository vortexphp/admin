<div class="flex items-center justify-between gap-4 rounded-lg border border-zinc-200/90 dark:border-zinc-800/80 bg-zinc-900/20 px-3 py-2.5">
    <span class="text-sm text-zinc-700 dark:text-zinc-300">{{ field.label }}</span>
    <label class="relative inline-flex cursor-pointer items-center">
        <input type="checkbox" name="{{ field.name }}" value="1" class="peer sr-only"
               {% if values[field.name] %}checked{% endif %}>
        <span class="peer h-6 w-10 shrink-0 rounded-full bg-zinc-800 ring-1 ring-zinc-700 transition peer-checked:bg-emerald-600 peer-checked:ring-emerald-500/40 peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-zinc-400 after:absolute after:left-0.5 after:top-0.5 after:size-5 after:rounded-full after:bg-zinc-200 after:shadow after:transition after:content-[''] peer-checked:after:translate-x-4 peer-checked:after:bg-white" aria-hidden="true"></span>
    </label>
</div>
