{% if cell %}
    {% set mh = col.maxHeightPx|default(48) %}
    {% set mw = col.maxWidthPx|default(null) %}
    {% set style = 'max-height:' ~ mh ~ 'px' ~ (mw is not null ? ';max-width:' ~ mw ~ 'px' : '') %}
    <span class="adm-img-thumb inline-flex align-middle">
    {% if col.openOriginalInNewTab|default(false) %}
        <a href="{{ cell|e('html_attr') }}" target="_blank" rel="noopener noreferrer" class="inline-block rounded-md ring-1 ring-zinc-600/70 transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-500/50" title="Open image">
            <img src="{{ cell|e('html_attr') }}" alt="" loading="lazy" decoding="async" class="h-auto w-auto max-w-none object-contain align-middle rounded-md" style="{{ style|e('html_attr') }}">
        </a>
    {% else %}
        <img src="{{ cell|e('html_attr') }}" alt="" loading="lazy" decoding="async" class="inline-block rounded-md object-contain align-middle ring-1 ring-zinc-600/70" style="{{ style|e('html_attr') }}">
    {% endif %}
    </span>
{% else %}
    <span class="inline-flex items-center gap-1.5 text-zinc-950 dark:text-zinc-500">
        <svg class="h-4 w-4 shrink-0 text-zinc-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008H12V8.25Z"/></svg>
        <span>{{ col.emptyLabel|default('—') }}</span>
    </span>
{% endif %}
