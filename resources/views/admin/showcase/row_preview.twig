<div class="space-y-3 text-sm text-zinc-200">
    <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Rendered row payload</p>
    <dl class="grid gap-2 sm:grid-cols-2">
        {% for key, val in row %}
            <dt class="text-zinc-500">{{ key }}</dt>
            <dd class="font-mono text-xs text-zinc-300">{{ val }}</dd>
        {% endfor %}
    </dl>
</div>
