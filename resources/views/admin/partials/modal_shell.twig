{# Host for admin.modal.js: clone <template> contents into data-adm-modal-body #}
{# Tailwind .flex can override the [hidden] attribute alone; keep .hidden class in sync in admin.modal.js #}
<div id="adm_modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4" hidden role="dialog" aria-modal="true" aria-labelledby="adm_modal_title">
    <div class="absolute inset-0 bg-zinc-900/40 dark:bg-zinc-950/75 backdrop-blur-[1px]" data-adm-modal-backdrop tabindex="-1" aria-hidden="true"></div>
    <div class="relative z-10 max-h-[min(90vh,42rem)] w-full max-w-lg overflow-hidden rounded-xl border border-zinc-300/90 dark:border-zinc-700/90 bg-white dark:bg-zinc-950 shadow-2xl ring-1 ring-zinc-200/80 dark:ring-zinc-800/80" data-adm-modal-panel>
        <div class="flex items-center justify-between gap-3 border-b border-zinc-200/90 dark:border-zinc-800/80 bg-zinc-100/95 dark:bg-zinc-900/60 px-4 py-3">
            <h2 id="adm_modal_title" class="min-w-0 flex-1 truncate pr-2 text-base font-semibold tracking-tight text-zinc-900 dark:text-zinc-100" data-adm-modal-title></h2>
            <button type="button" class="shrink-0 rounded-md p-1.5 text-zinc-600 dark:text-zinc-400 transition-colors hover:bg-zinc-200 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:text-zinc-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-500/45 dark:focus-visible:ring-zinc-500/45" data-adm-modal-close aria-label="Close">×</button>
        </div>
        <div class="max-h-[min(70vh,32rem)] overflow-y-auto px-4 py-4" data-adm-modal-body></div>
    </div>
</div>
