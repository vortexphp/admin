{# Modal body cloned into #adm_modal (see admin.modal.js). @var content array from ModalRowAction #}
{% if content.type == 'form' %}
    <form method="post" action="{{ route(content.route, content.routeParams) }}" class="flex flex-col gap-3">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% if content.body is defined and content.body %}
            {{ content.body|raw }}
        {% else %}
            {% include 'admin/partials/modal_form_fields.twig' with { fields: content.fields, fieldIdPrefix: modalId } only %}
        {% endif %}
        <div class="mt-1 flex flex-wrap justify-end gap-2 border-t border-zinc-800/80 pt-3">
            <button type="button" class="inline-flex items-center rounded-lg border border-zinc-700 bg-transparent px-3.5 py-2 text-sm font-medium text-zinc-200 ring-1 ring-zinc-800/40 hover:bg-zinc-900/60" data-adm-modal-close data-adm-modal-autofocus>Cancel</button>
            {% if content.danger|default(false) %}
                <button type="submit" class="inline-flex items-center rounded-lg border border-rose-500/40 bg-rose-600 px-3.5 py-2 text-sm font-medium text-white shadow-sm hover:bg-rose-500">{{ content.submitLabel|default('Submit') }}</button>
            {% else %}
                <button type="submit" class="inline-flex items-center rounded-lg border border-zinc-600/40 bg-zinc-100 px-3.5 py-2 text-sm font-medium text-zinc-950 shadow-sm ring-1 ring-zinc-800/30 hover:bg-white">{{ content.submitLabel|default('Submit') }}</button>
            {% endif %}
        </div>
    </form>
{% elseif content.type == 'html' %}
    <div class="text-sm leading-relaxed text-zinc-300">{{ content.body|raw }}</div>
    {% if content.showCloseFooter|default(true) %}
        <div class="mt-4 flex justify-end border-t border-zinc-800/80 pt-3">
            <button type="button" class="inline-flex items-center rounded-lg border border-zinc-700 bg-transparent px-3.5 py-2 text-sm font-medium text-zinc-200 ring-1 ring-zinc-800/40 hover:bg-zinc-900/60" data-adm-modal-close data-adm-modal-autofocus>Close</button>
        </div>
    {% endif %}
{% elseif content.type == 'include' %}
    {% include content.template with content.with|merge({ slug: slug, csrfToken: csrfToken, modalId: modalId }) only %}
{% endif %}
