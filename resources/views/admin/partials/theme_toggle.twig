{% import 'admin/partials/icon_svg.twig' as icons %}
<button type="button" id="adm-theme-toggle" class="{{ theme_toggle_class|default('inline-flex items-center justify-center rounded-xl border border-zinc-200/90 bg-white p-2 text-zinc-600 shadow-sm ring-1 ring-zinc-200/70 transition-colors hover:border-zinc-300 hover:bg-zinc-50 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-300 dark:ring-zinc-800/80 dark:hover:border-zinc-600 dark:hover:bg-zinc-800/90 dark:hover:text-zinc-100') }}">
    <span class="dark:hidden" aria-hidden="true">{{ icons.r('moon', 'h-5 w-5') }}</span>
    <span class="hidden dark:inline" aria-hidden="true">{{ icons.r('sun', 'h-5 w-5') }}</span>
</button>
