<a href="{{ item.href }}" class="group flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100/90 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800/70 dark:hover:text-zinc-100"{% if item.external|default(false) %} target="_blank" rel="noopener noreferrer"{% endif %}>
    {% if item.iconClass %}
        <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center text-zinc-400 group-hover:text-zinc-600 dark:text-zinc-500 dark:group-hover:text-zinc-300 {{ item.iconClass }}" aria-hidden="true"></span>
    {% elseif item.icon %}
        <span class="flex h-5 w-5 shrink-0 items-center justify-center text-base leading-none text-zinc-400 opacity-95 group-hover:text-zinc-600 dark:text-zinc-500 dark:group-hover:text-zinc-300" aria-hidden="true">{{ item.icon }}</span>
    {% endif %}
    <span>{{ item.label }}</span>
</a>
