<a href="{{ item.href }}" class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm text-zinc-400 transition-colors hover:bg-zinc-900 hover:text-zinc-100">
    {% if item.iconClass %}
        <span class="inline-flex shrink-0 text-zinc-500 {{ item.iconClass }}" aria-hidden="true"></span>
    {% elseif item.icon %}
        <span class="shrink-0 text-base leading-none text-zinc-500 opacity-90" aria-hidden="true">{{ item.icon }}</span>
    {% endif %}
    <span>{{ item.label }}</span>
</a>
