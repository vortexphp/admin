<div>
    {% if widget.title %}
        <h2 class="mb-4 text-sm font-semibold text-zinc-200">{{ widget.title }}</h2>
    {% endif %}
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {% for item in widget.items %}
            <div class="rounded-xl border border-zinc-800/80 bg-zinc-900/30 px-4 py-4 shadow-sm ring-1 ring-zinc-800/50">
                <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">{{ item.label }}</p>
                <p class="mt-1 text-2xl font-semibold tracking-tight text-zinc-100">{{ item.value }}</p>
                {% if item.hint is defined and item.hint %}
                    <p class="mt-2 text-xs text-zinc-500">{{ item.hint }}</p>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>
