<div class="max-w-3xl">
    {% if widget.title %}
        <h2 class="mb-3 text-sm font-semibold text-zinc-200">{{ widget.title }}</h2>
    {% endif %}
    {% if widget.items is empty %}
        <p class="text-sm text-zinc-500">No resources configured.</p>
    {% else %}
        <ul class="divide-y divide-zinc-800/80 rounded-xl border border-zinc-800/80 bg-zinc-900/20">
            {% for r in widget.items %}
                <li>
                    <a class="flex items-center justify-between gap-3 px-4 py-3.5 text-sm text-zinc-200 transition-colors hover:bg-zinc-900/40" href="{{ route('admin.resource.index', { slug: r.slug }) }}">
                        <span class="font-medium">{{ r.label }}</span>
                        <span class="text-xs text-zinc-500">{{ r.slug }}</span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
