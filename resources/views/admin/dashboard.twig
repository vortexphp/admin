{% extends 'admin/layout.twig' %}

{% block doc_title %}{{ title }} — {{ adminBranding.name }}{% endblock %}

{% block heading %}{{ title }}{% endblock %}

{% block body %}
<div class="space-y-10">
    {% for widget in dashboardWidgets %}
        {% include 'admin/widgets/' ~ widget.kind ~ '.twig' with { widget: widget } %}
    {% endfor %}
</div>
{% endblock %}
